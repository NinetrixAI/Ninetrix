def _stdin_approve(tool_name: str) -> bool:
    """Interactive stdin fallback for human approval (used when no DB persistence)."""
    _console.print(f"\n[bold yellow]⏸ Approval required:[/bold yellow] [bold cyan]{tool_name}[/bold cyan]")
