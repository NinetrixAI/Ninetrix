def main() -> None:
    print(f"Agent '{{ agent.name }}' running ({PROVIDER}/{MODEL})")
    print("Send a message (Ctrl+C to quit):\n")

    while True:
        try:
            user_input = input("> ").strip()
        except (KeyboardInterrupt, EOFError):
            print("\nBye.")
            break

        if not user_input:
            continue

        _msgs = []
        if SYSTEM_PROMPT:
            _msgs.append({"role": "system", "content": SYSTEM_PROMPT})
        _msgs.append({"role": "user", "content": user_input})
        response = litellm.completion(
            model=LITELLM_MODEL,
            messages=_msgs,
            max_tokens=MAX_TOKENS,
            temperature=TEMP,
        )
        _console.print(response.choices[0].message.content or "", markup=False, highlight=False)

        print()


if __name__ == "__main__":
    main()

