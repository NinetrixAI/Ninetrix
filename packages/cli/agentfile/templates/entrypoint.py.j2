{% if has_planned_execution %}
async def _plan_phase(user_input: str, tool_defs: list) -> dict | None:
    """
    Ask the main LLM to produce a JSON execution plan before any tools run.
    Returns the plan dict, or None if planning fails (caller falls back to direct mode).
    """
    tool_names: list[str] = []
    for t in tool_defs:
        if isinstance(t, dict):
            n = t.get("name") or t.get("function", {}).get("name", "")
        else:
            n = getattr(t, "name", "") or ""
        if n:
            tool_names.append(n)

    planning_msg = (
        f"The user wants you to: {user_input}\n\n"
        f"Available tools: {', '.join(tool_names) or 'none'}\n\n"
        "Before using any tools, output ONLY a JSON plan with this exact structure "
        "(no markdown, no explanation):\n"
        '{"goal": "brief one-line goal", '
        '"steps": [{"id": 1, "description": "what to do", "tool": "tool_name_or_null"}]}\n'
        f"Maximum {MAX_PLAN_STEPS} steps."
    )

    try:
        _plan_msgs = []
        if SYSTEM_PROMPT:
            _plan_msgs.append({"role": "system", "content": SYSTEM_PROMPT})
        _plan_msgs.append({"role": "user", "content": planning_msg})
        resp = await litellm.acompletion(
            model=LITELLM_MODEL, max_tokens=512, temperature=0.0, messages=_plan_msgs,
        )
        text = (resp.choices[0].message.content or "").strip()
        text = text.removeprefix("```json").removeprefix("```").removesuffix("```").strip()
        # Extract just the JSON object — handles trailing text / explanations after the closing brace
        _j_start = text.find("{")
        _j_end   = text.rfind("}") + 1
        if _j_start == -1 or _j_end == 0:
            raise ValueError("No JSON object found in plan response")
        plan = json.loads(text[_j_start:_j_end])
        if "steps" not in plan or not isinstance(plan["steps"], list):
            print("[plan] Warning: plan JSON missing 'steps' — running in direct mode.",
                  file=sys.stderr)
            return None
        plan["steps"] = plan["steps"][:MAX_PLAN_STEPS]
        return plan
    except Exception as exc:
        print(f"[plan] Warning: could not generate plan: {exc} — running in direct mode.",
              file=sys.stderr)
        return None


