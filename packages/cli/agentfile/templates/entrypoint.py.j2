def _extract_text(content_blocks: list) -> str:
    """Extract text from MCP call_tool result content blocks."""
    parts = []
    for block in (content_blocks or []):
        if hasattr(block, "text"):
            parts.append(block.text)
        elif isinstance(block, dict) and "text" in block:
            parts.append(block["text"])
        elif getattr(block, "type", None) == "image":
            parts.append("[image result omitted]")
    return "\n".join(parts) if parts else "(no output)"


def _trim_messages(messages: list) -> list:
    """Sliding-window history to stay within HISTORY_WINDOW_CHARS.

    Always pins system messages and the first user message (original task).
    Trims oldest non-pinned messages first. Never orphans a tool_use block.
    Filters out role="thinking" messages — those are internal scratchpad entries
    not valid for any LLM API provider.
    """
    if not messages:
        return messages
    # Strip internal thinking messages before any LLM call
    messages = [_m for _m in messages if _m.get("role") != "thinking"]

    # Collect pinned: all system msgs + first user msg
    pinned: list = []
    rest: list = []
    _found_first_user = False
    for _m in messages:
        if _m.get("role") == "system" or not _found_first_user:
            pinned.append(_m)
            if _m.get("role") == "user":
                _found_first_user = True
        else:
            rest.append(_m)

    _pinned_size = sum(len(json.dumps(_m, default=str)) for _m in pinned)
    _budget = HISTORY_WINDOW_CHARS - _pinned_size
    if _budget <= 0:
        return pinned  # extreme case: pinned alone exceeds budget

    # Walk rest from the end, keeping what fits
    _kept: list = []
    for _m in reversed(rest):
        _size = len(json.dumps(_m, default=str))
        if _size > _budget and _kept:
            break
        _kept.insert(0, _m)
        _budget -= _size

    # Don't start with a bare tool-result message (needs preceding assistant)
    while _kept and _kept[0].get("role") == "tool":
        _kept = _kept[1:]

    _result = pinned + _kept
    if len(_result) < len(messages):
        _trimmed = len(messages) - len(_result)
        print(f"[memory] Trimmed {_trimmed} old message(s) to stay within context window.",
              file=sys.stderr)
    return _result




