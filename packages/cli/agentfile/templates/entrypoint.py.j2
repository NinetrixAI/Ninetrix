async def _thinking_phase(user_input: str) -> tuple[str | None, int, int]:
    """
    Pre-run reasoning step: ask the LLM (no tools) to think about the task.
    Returns (reasoning_text | None, input_tokens, output_tokens).
    Silently returns (None, 0, 0) on timeout or any error so the agent continues normally.
    """
    _default_instruction = (
        "Before taking any actions, think carefully about the following task.\n"
        "Consider: what is the user actually asking for? What are the key steps? "
        "What are potential edge cases or risks? What is the best approach?\n"
        "Write your reasoning freely — this is your internal scratchpad, not the final answer.\n\n"
        f"Task: {user_input}"
    )
    _instruction = (_THINKING_PROMPT + f"\n\nTask: {user_input}") if _THINKING_PROMPT else _default_instruction

    _msgs = []
    if SYSTEM_PROMPT:
        _msgs.append({"role": "system", "content": SYSTEM_PROMPT})
    _msgs.append({"role": "user", "content": _instruction})

    try:
        _resp = await asyncio.wait_for(
            litellm.acompletion(
                model=_THINKING_MODEL,
                max_tokens=_THINKING_MAX_TOKENS,
                temperature=_THINKING_TEMP,
                messages=_msgs,
            ),
            timeout=_THINKING_TIMEOUT,
        )
        _in_tok  = (getattr(_resp.usage, "prompt_tokens",    0) or 0) if _resp.usage else 0
        _out_tok = (getattr(_resp.usage, "completion_tokens", 0) or 0) if _resp.usage else 0
        return (_resp.choices[0].message.content or "").strip() or None, _in_tok, _out_tok
    except asyncio.TimeoutError:
        print(f"[thinking] Warning: thinking step timed out after {_THINKING_TIMEOUT}s — skipping.", file=sys.stderr)
        return None, 0, 0
    except Exception as exc:
        print(f"[thinking] Warning: thinking step failed: {exc}", file=sys.stderr)
        return None, 0, 0


