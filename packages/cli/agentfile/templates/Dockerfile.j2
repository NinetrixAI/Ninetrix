# Generated by ninetrix — do not edit manually.
# Agent: {{ agent.name }}  |  Model: {{ agent.model }}  |  Provider: {{ agent.provider }}

FROM {{ base_image }}

LABEL org.opencontainers.image.title="{{ agent.name }}"
LABEL org.opencontainers.image.description="{{ agent.description }}"
LABEL org.opencontainers.image.source="https://github.com/ninetrix/ninetrix"

WORKDIR /app

{% if needs_node %}
# Install Node.js 20 (required for npx-based MCP servers)
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Pre-install MCP npm packages at build time to avoid runtime downloads on cold starts
{% for td in mcp_tool_defs %}{% if td.sdef and td.sdef.type == "npx" %}
RUN npm install -g {{ td.sdef.package }}
{% endif %}{% endfor %}
{% endif %}
{% if needs_uv %}
# Install uv (required for uvx-based MCP servers)
RUN pip install --no-cache-dir "uv>=0.4"

# Pre-install MCP uvx packages at build time to avoid runtime downloads on cold starts
{% for td in mcp_tool_defs %}{% if td.sdef and td.sdef.type == "uvx" %}
RUN uv tool install {{ td.sdef.package }}
{% endif %}{% endfor %}
{% endif %}
# Install Python runtime dependencies
RUN pip install --no-cache-dir \
    "litellm>=1.50" \
{% if has_mcp_tools %}
    "mcp>=1.0" \
{% endif %}
{% if use_mcp_gateway %}
    "httpx>=0.27" \
{% endif %}
{% if agent.tools %}
    requests>=2.31 \
{% endif %}
    pyyaml>=6.0 \
    rich>=13
{% if has_persistence %}

RUN pip install --no-cache-dir "psycopg[binary]>=3.0"
{% endif %}
{% if has_composio_tools %}

# Install Composio SDK
RUN pip install --no-cache-dir composio
{% endif %}
{% if has_s3_volumes %}

# Install AWS CLI for S3 volume sync
RUN pip install --no-cache-dir awscli
{% endif %}
{% if has_webhook_triggers or is_multi_agent or is_saas_runner or has_invoke_server %}

RUN pip install --no-cache-dir "fastapi>=0.104" "uvicorn[standard]>=0.24"
{% endif %}
{% if has_schedule_triggers %}

RUN pip install --no-cache-dir "apscheduler>=3.10"
{% endif %}
{% if has_collaborators %}

RUN pip install --no-cache-dir "aiohttp>=3.9"
{% endif %}

# Copy the agentfile
COPY agentfile.yaml /app/agentfile.yaml

# Copy agent entrypoint
COPY entrypoint.py /app/entrypoint.py

ENV PYTHONUNBUFFERED=1
ENV AGENTFILE_MODEL="{{ agent.model }}"
ENV AGENTFILE_PROVIDER="{{ agent.provider }}"
ENV AGENTFILE_TEMPERATURE="{{ agent.temperature }}"

{% if has_webhook_triggers %}
EXPOSE {{ webhook_port }}
{% endif %}
{% if is_multi_agent %}
EXPOSE {{ invoke_port }}
{% endif %}
# Secrets injected at runtime via env vars — never baked in
# e.g.: docker run -e ANTHROPIC_API_KEY=sk-... {{ agent.image_name() }}

ENTRYPOINT ["python", "entrypoint.py"]
