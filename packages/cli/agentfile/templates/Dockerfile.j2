# syntax=docker/dockerfile:1
# Generated by ninetrix — do not edit manually.
# Agent: {{ agent.name }}  |  Model: {{ agent.model }}  |  Provider: {{ agent.provider }}

FROM {{ base_image }}

LABEL org.opencontainers.image.title="{{ agent.name }}"
LABEL org.opencontainers.image.description="{{ agent.description }}"
LABEL org.opencontainers.image.source="https://github.com/ninetrix/ninetrix"

WORKDIR /app
{% if collected_deps.apt or has_apt_packages %}

# System packages (apt) — cache mounts survive across builds
RUN --mount=type=cache,target=/var/cache/apt \
    --mount=type=cache,target=/var/lib/apt/lists \
    apt-get update && apt-get install -y --no-install-recommends{% for _p in collected_deps.apt %} {{ _p }}{% endfor %}{% for _p in apt_packages %} {{ _p }}{% endfor %}

{% endif %}
{% if has_npm_packages %}

# npm packages — cache mount reuses downloaded packages
RUN --mount=type=cache,target=/root/.npm \
    npm install -g {{ npm_packages | join(' ') }}
{% endif %}

# Install Python runtime dependencies + ninetrix-sdk
# litellm pin: review quarterly — litellm has a history of breaking changes
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install \
    "litellm>=1.50,<2.0" \
    "pyyaml>=6.0" \
    "rich>=13" \
    "ninetrix-sdk"{% for _pkg in collected_deps.pip %} \
    "{{ _pkg }}"{% endfor %}{% for _pkg in pip_packages %} \
    "{{ _pkg }}"{% endfor %}

# Copy the agentfile
COPY agentfile.yaml /app/agentfile.yaml

# Copy agent entrypoint
COPY entrypoint.py /app/entrypoint.py
{% if has_local_tools %}

# Copy local @Tool Python files
COPY tools/ /app/tools/
{% endif %}

ENV PYTHONUNBUFFERED=1
ENV AGENTFILE_MODEL="{{ agent.model }}"
ENV AGENTFILE_PROVIDER="{{ agent.provider }}"
ENV AGENTFILE_TEMPERATURE="{{ agent.temperature }}"

{% if has_webhook_triggers %}
EXPOSE {{ webhook_port }}
{% endif %}
{% if is_multi_agent %}
EXPOSE {{ invoke_port }}
{% endif %}
# Secrets injected at runtime via env vars — never baked in
# e.g.: docker run -e ANTHROPIC_API_KEY=sk-... {{ agent.image_name() }}

ENTRYPOINT ["python", "entrypoint.py"]
