# syntax=docker/dockerfile:1
# Generated by ninetrix — do not edit manually.
# Agent: {{ agent.name }}  |  Model: {{ agent.model }}  |  Provider: {{ agent.provider }}

FROM {{ base_image }}

LABEL org.opencontainers.image.title="{{ agent.name }}"
LABEL org.opencontainers.image.description="{{ agent.description }}"
LABEL org.opencontainers.image.source="https://github.com/ninetrix/ninetrix"

WORKDIR /app
{% if collected_deps.apt_repos %}

# Add custom APT repositories (from Tool Hub)
RUN apt-get update && apt-get install -y --no-install-recommends curl gnupg{% for _repo in collected_deps.apt_repos %} \
    && curl -fsSL {{ _repo.keyring_url }} -o /usr/share/keyrings/{{ _repo.keyring_url.split('/')[-1] }} \
    && echo '{{ _repo.repo }}' > /etc/apt/sources.list.d/{{ _repo.repo.split('/')[-2] }}.list{% endfor %} \
    && apt-get update
{% endif %}
{% if collected_deps.apt or has_apt_packages %}

# System packages (apt)
RUN --mount=type=cache,target=/var/cache/apt \
    --mount=type=cache,target=/var/lib/apt/lists \
    apt-get update && apt-get install -y --no-install-recommends{% for _p in collected_deps.apt %} {{ _p }}{% endfor %}{% for _p in apt_packages %} {{ _p }}{% endfor %}

{% endif %}
{% if collected_deps.npm or has_npm_packages %}

# Install Node.js + npm packages
RUN --mount=type=cache,target=/var/cache/apt \
    apt-get update && apt-get install -y --no-install-recommends curl \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g{% for _p in collected_deps.npm %} {{ _p }}{% endfor %}{% for _p in npm_packages %} {{ _p }}{% endfor %}

{% endif %}
{% for _cmd in collected_deps.install %}

# CLI tool install
RUN {{ _cmd }}
{% endfor %}
{% if collected_deps.install %}

# Ensure user-installed CLIs are on PATH (~/.local/bin is the standard install location)
ENV PATH="/root/.local/bin:${PATH}"
{% endif %}

# Install Python runtime dependencies + ninetrix-sdk
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install \
    "litellm>=1.50,<2.0" \
    "pyyaml>=6.0" \
    "rich>=13" \
    "ninetrix-sdk"{% for _pkg in collected_deps.pip %} \
    "{{ _pkg }}"{% endfor %}{% for _pkg in pip_packages %} \
    "{{ _pkg }}"{% endfor %}

# Copy the agentfile
COPY agentfile.yaml /app/agentfile.yaml

# Copy agent entrypoint
COPY entrypoint.py /app/entrypoint.py
{% if has_channel_triggers %}

# Copy ninetrix-channels package (not on PyPI — bundled from host)
COPY ninetrix_channels/ /app/ninetrix_channels/
ENV PYTHONPATH="/app:${PYTHONPATH}"
{% endif %}
{% if has_local_tools %}

# Copy local @Tool Python files
COPY tools/ /app/tools/
{% endif %}

ENV PYTHONUNBUFFERED=1
ENV AGENTFILE_MODEL="{{ agent.model }}"
ENV AGENTFILE_PROVIDER="{{ agent.provider }}"
ENV AGENTFILE_TEMPERATURE="{{ agent.temperature }}"

{% if has_webhook_triggers or has_channel_triggers %}
EXPOSE {{ webhook_port }}
{% endif %}
{% if is_multi_agent %}
EXPOSE {{ invoke_port }}
{% endif %}
# Secrets injected at runtime via env vars — never baked in
# e.g.: docker run -e ANTHROPIC_API_KEY=sk-... {{ agent.image_name() }}

ENTRYPOINT ["python", "entrypoint.py"]
