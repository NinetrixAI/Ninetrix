{% if has_collaborators %}
# ── Agent-to-agent transfer ───────────────────────────────────────────────────

async def _transfer_to_agent(
    agent: str, message: str, context: dict, thread_id: str,
    caller_trace_id: str = "",
) -> str:
    """Delegate a task to a collaborator agent via its /invoke endpoint."""
    url = PEER_URLS.get(agent.lower())
    if not url:
        _err = f"Agent '{agent}' not found. Known peers: {list(PEER_URLS)}"
        _post_runner_event("agent_transfer_failed", {
            "thread_id": thread_id, "from": AGENT_NAME, "to": agent,
            "error": "agent_not_found", "detail": _err,
        })
        return f"Error: {_err}"
    payload = {
        "thread_id": thread_id,
        "run_id": uuid.uuid4().hex,
        "caller_agent": AGENT_NAME,
        "message": message,
        "context": context,
        "parent_trace_id": caller_trace_id,
    }
    _post_runner_event("agent_transfer_started", {
        "thread_id": thread_id, "from": AGENT_NAME, "to": agent,
        "message_preview": message[:200],
    })
    print(f"[transfer→] {AGENT_NAME} → {agent}: {message[:120]}", flush=True)
    _start_ts = __import__("time").monotonic()

    # Retry once on connection error (not on agent-level errors)
    for _attempt in range(2):
        try:
            async with aiohttp.ClientSession() as _s:
                async with _s.post(
                    f"{url}/invoke",
                    json=payload,
                    timeout=aiohttp.ClientTimeout(total=TRANSFER_TIMEOUT),
                ) as _r:
                    data = await _r.json()
            if data.get("status") == "completed":
                result = str(data.get("result", ""))
            else:
                result = f"Agent '{agent}' returned error: {data.get('error', 'unknown')}"
            break
        except aiohttp.ClientConnectorError as exc:
            if _attempt == 0:
                print(f"[transfer] Connection to '{agent}' failed, retrying in 2s...",
                      file=sys.stderr, flush=True)
                await asyncio.sleep(2)
                continue
            result = f"Agent '{agent}' unreachable after retry: {type(exc).__name__}: {exc}"
            break
        except asyncio.TimeoutError:
            result = f"Agent '{agent}' timed out after {TRANSFER_TIMEOUT}s"
            break
        except Exception as exc:
            result = f"Agent '{agent}' call failed: {type(exc).__name__}: {exc}"
            break

    _elapsed_ms = int((__import__("time").monotonic() - _start_ts) * 1000)
    _is_error = result.startswith("Agent '") and ("error" in result.lower() or "unreachable" in result.lower() or "timed out" in result.lower() or "failed" in result.lower())

    if _is_error:
        _post_runner_event("agent_transfer_failed", {
            "thread_id": thread_id, "from": AGENT_NAME, "to": agent,
            "error": "transfer_error", "detail": result[:500],
            "duration_ms": _elapsed_ms,
        })
    else:
        _post_runner_event("agent_transfer_completed", {
            "thread_id": thread_id, "from": AGENT_NAME, "to": agent,
            "duration_ms": _elapsed_ms,
            "result_preview": result[:200],
        })

    print(f"[transfer←] {agent} → {AGENT_NAME}: {result[:120]} ({_elapsed_ms}ms)", flush=True)
    return result


{% if has_auto_routing %}
async def _auto_route(message: str, thread_id: str) -> str:
    """Use a cheap LLM call to pick the best collaborator, then forward the message."""
    _agents_desc = "\n".join(
        f"- {name}" for name in {{ collaborators | tojson }}
    )
    _route_prompt = (
        f"You are a message router. Pick the single best agent to handle this message.\n\n"
        f"Available agents:\n{_agents_desc}\n\n"
        f"Message: {message}\n\n"
        f"Respond with ONLY the agent name, nothing else."
    )
    try:
        _route_model = "{{ routing_provider }}/{{ routing_model }}"
        _route_resp = await litellm.acompletion(
            model=_route_model,
            messages=[{"role": "user", "content": _route_prompt}],
            temperature=0.0,
            max_tokens=32,
        )
        _picked = _route_resp.choices[0].message.content.strip().lower()
        # Validate the pick
        _valid = {n.lower(): n for n in {{ collaborators | tojson }}}
        if _picked not in _valid:
            # Fuzzy match: check if the response contains a valid name
            for _k, _v in _valid.items():
                if _k in _picked:
                    _picked = _k
                    break
            else:
                _picked = list(_valid.keys())[0]
                print(f"[router] Could not parse route, defaulting to '{_picked}'", file=sys.stderr, flush=True)
        _target = _valid[_picked]
        print(f"[router] → {_target}", flush=True)
        return await _transfer_to_agent(_target, message, {}, thread_id)
    except Exception as _exc:
        print(f"[router] Error: {_exc} — falling back to first collaborator", file=sys.stderr, flush=True)
        return await _transfer_to_agent({{ collaborators | tojson }}[0], message, {}, thread_id)


