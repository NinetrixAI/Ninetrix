{% if use_mcp_gateway %}
# ── MCP Gateway client (runtime tool discovery over HTTP JSON-RPC) ─────────────
_MCP_GATEWAY_URL       = os.environ.get("MCP_GATEWAY_URL",       {{ mcp_gateway_url | tojson }}).rstrip("/")
_MCP_GATEWAY_TOKEN     = os.environ.get("MCP_GATEWAY_TOKEN",     {{ mcp_gateway_token | tojson }})
_MCP_GATEWAY_ORG_ID = os.environ.get("MCP_GATEWAY_ORG_ID", {{ mcp_gateway_org_id | tojson }})

_GW_HEADERS: dict = ({"Authorization": f"Bearer {_MCP_GATEWAY_TOKEN}"} if _MCP_GATEWAY_TOKEN else {})
_GW_ENDPOINT = f"{_MCP_GATEWAY_URL}/v1/mcp/{_MCP_GATEWAY_ORG_ID}"


class _MCPGatewaySession:
    """
    Drop-in replacement for mcp.ClientSession — proxies tool calls to the gateway.
    Implements the same .call_tool(name, args) interface used in _run_turn().
    """
    def __init__(self, http: httpx.AsyncClient):
        self._http = http

    async def call_tool(self, name: str, args: dict):
        _req_id = str(uuid.uuid4())[:8]
        payload = {
            "jsonrpc": "2.0", "id": _req_id,
            "method": "tools/call",
            "params": {"name": name, "arguments": args},
        }
        try:
            resp = await self._http.post(_GW_ENDPOINT, json=payload, headers=_GW_HEADERS)
        except Exception as _conn_exc:
            _t = type(_conn_exc).__name__
            if "ConnectError" in _t or "ConnectionRefused" in _t:
                raise RuntimeError(
                    f"Gateway unreachable at {_MCP_GATEWAY_URL}. Is it running? "
                    f"Check: ninetrix mcp status"
                )
            raise RuntimeError(f"Gateway connection error: {_t}: {_conn_exc}")
        if resp.status_code in (401, 403):
            raise RuntimeError("Authentication failed. Check MCP_GATEWAY_TOKEN")
        resp.raise_for_status()
        body = resp.json()
        if "error" in body:
            err = body["error"]
            code = err.get("code", 0)
            msg = err.get("message", "MCP Gateway error")
            if code == -32010:
                data = err.get("data", {})
                integration_id = data.get("integration_id", "")
                auth_url = data.get("auth_url", "")
                print(f"\n⚠  Tool '{name}' requires authorization.", file=sys.stderr, flush=True)
                print(f"   Integration '{integration_id}' is not connected.", file=sys.stderr, flush=True)
                if auth_url:
                    print(f"\n   Connect now:\n   {auth_url}\n", file=sys.stderr, flush=True)
                    print(f"   Re-run after connecting in the dashboard.\n", file=sys.stderr, flush=True)
                raise SystemExit(1)
            elif code == -32601:
                raise RuntimeError(f"Tool '{name}' not found on gateway. Run: ninetrix mcp status")
            else:
                raise RuntimeError(f"Tool '{name}' failed: {msg}. Check worker logs: ninetrix mcp logs")
        result = body.get("result", {})
        # Wrap as object with .content so _extract_text() works unchanged
        content = result.get("content") or [{"type": "text", "text": str(result)}]
        return type("_GWResult", (), {"content": content, "isError": result.get("isError", False)})()


_MCP_INIT_TIMEOUT = int(os.environ.get("MCP_INIT_TIMEOUT", "60"))


async def _init_mcp_gateway(http: httpx.AsyncClient) -> tuple[dict, list]:
    """
    Connect to the MCP Gateway, discover available tools, and return
    (sessions_by_tool, tool_definitions) ready for the LLM API.

    Hard-fails (sys.exit) when the gateway is unreachable — an agent with
    mcp:// tools cannot function without it.
    """
    if not _MCP_GATEWAY_URL:
        print(
            "[mcp-gateway] ERROR: No MCP gateway URL configured.\n"
            "  MCP tools require a running gateway.\n"
            "  Start one with:  ninetrix dev --mcp\n"
            "  Or set:          MCP_GATEWAY_URL=http://localhost:9090",
            file=sys.stderr, flush=True,
        )
        raise SystemExit(1)

    session = _MCPGatewaySession(http)
    try:
        # Initialize handshake
        await asyncio.wait_for(
            http.post(_GW_ENDPOINT, json={"jsonrpc":"2.0","id":0,"method":"initialize","params":{}},
                      headers=_GW_HEADERS),
            timeout=_MCP_INIT_TIMEOUT,
        )
        # Discover tools
        list_resp = await asyncio.wait_for(
            http.post(_GW_ENDPOINT, json={"jsonrpc":"2.0","id":1,"method":"tools/list","params":{}},
                      headers=_GW_HEADERS),
            timeout=_MCP_INIT_TIMEOUT,
        )
        list_resp.raise_for_status()
        body = list_resp.json()
        if "error" in body:
            err = body["error"]
            code = err.get("code", 0)
            msg = err.get("message", str(err))
            if code in (-32010,):
                print(f"[mcp-gateway] ERROR: Authentication failed — check MCP_GATEWAY_TOKEN", file=sys.stderr)
            else:
                print(f"[mcp-gateway] ERROR: Gateway returned error: {msg}", file=sys.stderr)
            raise SystemExit(1)

        tools = body.get("result", {}).get("tools", [])
        sessions_by_tool = {t["name"]: session for t in tools}
        tool_definitions = [
            {
                "type": "function",
                "function": {
                    "name": t["name"],
                    "description": t.get("description", ""),
                    "parameters": t.get("inputSchema") or {"type": "object", "properties": {}},
                },
            }
            for t in tools
        ]
        names = [t["name"] for t in tools]
        print(f"[mcp-gateway] Connected to {_MCP_GATEWAY_URL} — {len(tools)} tool(s): {', '.join(names)}",
              flush=True)
        return sessions_by_tool, tool_definitions

    except SystemExit:
        raise
    except asyncio.TimeoutError:
        print(
            f"[mcp-gateway] ERROR: Timed out connecting to gateway at {_MCP_GATEWAY_URL}\n"
            f"  Waited {_MCP_INIT_TIMEOUT}s. Is the gateway running?\n"
            f"  Check with:   ninetrix mcp status\n"
            f"  Start with:   ninetrix dev --mcp\n"
            f"  Increase with: MCP_INIT_TIMEOUT=120",
            file=sys.stderr, flush=True,
        )
        raise SystemExit(1)
    except Exception as exc:
        _exc_type = type(exc).__name__
        if "ConnectionRefused" in _exc_type or "ConnectError" in _exc_type:
            print(
                f"[mcp-gateway] ERROR: Gateway unreachable at {_MCP_GATEWAY_URL}\n"
                f"  Connection refused. Is the gateway running?\n"
                f"  Check with:  ninetrix mcp status\n"
                f"  Start with:  ninetrix dev --mcp",
                file=sys.stderr, flush=True,
            )
        else:
            print(
                f"[mcp-gateway] ERROR: {_exc_type}: {exc}\n"
                f"  Could not connect to gateway at {_MCP_GATEWAY_URL}\n"
                f"  Check worker logs: ninetrix mcp logs",
                file=sys.stderr, flush=True,
            )
        raise SystemExit(1)


{% endif %}
