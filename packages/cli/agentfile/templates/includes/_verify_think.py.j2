{% if has_thinking_step %}
# ── Thinking step config ──────────────────────────────────────────────────────
# All values are overridable at runtime — no rebuild needed.
_THINKING_ENABLED    = os.environ.get("AGENTFILE_THINKING_ENABLED",     "true").lower() not in ("false", "0", "no")
_THINKING_PROVIDER   = os.environ.get("AGENTFILE_THINKING_PROVIDER",    "{{ thinking_provider }}")
_THINKING_PREFIX     = _PROVIDER_PREFIX.get(_THINKING_PROVIDER, _THINKING_PROVIDER)
_THINKING_MODEL_NAME = os.environ.get("AGENTFILE_THINKING_MODEL",       "{{ thinking_model }}")
_THINKING_MODEL      = f"{_THINKING_PREFIX}/{_THINKING_MODEL_NAME}"
_THINKING_MAX_TOKENS = int(os.environ.get("AGENTFILE_THINKING_MAX_TOKENS",   "{{ thinking_max_tokens }}"))
_THINKING_TEMP       = float(os.environ.get("AGENTFILE_THINKING_TEMPERATURE","{{ thinking_temperature }}"))
_THINKING_MIN_LEN    = int(os.environ.get("AGENTFILE_THINKING_MIN_LENGTH",   "{{ thinking_min_input_length }}"))
_THINKING_PROMPT     = os.environ.get("AGENTFILE_THINKING_PROMPT", {{ thinking_prompt | tojson }})
_THINKING_TIMEOUT    = 30.0  # seconds before abandoning the thinking call


async def _thinking_phase(user_input: str) -> tuple[str | None, int, int]:
    """
    Pre-run reasoning step: ask the LLM (no tools) to think about the task.
    Returns (reasoning_text | None, input_tokens, output_tokens).
    Silently returns (None, 0, 0) on timeout or any error so the agent continues normally.
    """
    _default_instruction = (
        "Before taking any actions, think carefully about the following task.\n"
        "Consider: what is the user actually asking for? What are the key steps? "
        "What are potential edge cases or risks? What is the best approach?\n"
        "Write your reasoning freely — this is your internal scratchpad, not the final answer.\n\n"
        f"Task: {user_input}"
    )
    _instruction = (_THINKING_PROMPT + f"\n\nTask: {user_input}") if _THINKING_PROMPT else _default_instruction

    _msgs = []
    if SYSTEM_PROMPT:
        _msgs.append({"role": "system", "content": SYSTEM_PROMPT})
    _msgs.append({"role": "user", "content": _instruction})

    try:
        _resp = await asyncio.wait_for(
            litellm.acompletion(
                model=_THINKING_MODEL,
                max_tokens=_THINKING_MAX_TOKENS,
                temperature=_THINKING_TEMP,
                messages=_msgs,
            ),
            timeout=_THINKING_TIMEOUT,
        )
        _in_tok  = (getattr(_resp.usage, "prompt_tokens",    0) or 0) if _resp.usage else 0
        _out_tok = (getattr(_resp.usage, "completion_tokens", 0) or 0) if _resp.usage else 0
        _charge(_THINKING_MODEL, _in_tok, _out_tok, "thinking")
        return (_resp.choices[0].message.content or "").strip() or None, _in_tok, _out_tok
    except asyncio.TimeoutError:
        print(f"[thinking] Warning: thinking step timed out after {_THINKING_TIMEOUT}s — skipping.", file=sys.stderr)
        return None, 0, 0
    except Exception as exc:
        print(f"[thinking] Warning: thinking step failed: {exc}", file=sys.stderr)
        return None, 0, 0


{% endif %}
{% if has_planned_execution %}
async def _plan_phase(user_input: str, tool_defs: list) -> dict | None:
    """
    Ask the main LLM to produce a JSON execution plan before any tools run.
    Returns the plan dict, or None if planning fails (caller falls back to direct mode).
    """
    tool_names: list[str] = []
    for t in tool_defs:
        if isinstance(t, dict):
            n = t.get("name") or t.get("function", {}).get("name", "")
        else:
            n = getattr(t, "name", "") or ""
        if n:
            tool_names.append(n)

    planning_msg = (
        f"The user wants you to: {user_input}\n\n"
        f"Available tools: {', '.join(tool_names) or 'none'}\n\n"
        "Before using any tools, output ONLY a JSON plan with this exact structure "
        "(no markdown, no explanation):\n"
        '{"goal": "brief one-line goal", '
        '"steps": [{"id": 1, "description": "what to do", "tool": "tool_name_or_null"}]}\n'
        f"Maximum {MAX_PLAN_STEPS} steps."
    )

    try:
        _plan_msgs = []
        if SYSTEM_PROMPT:
            _plan_msgs.append({"role": "system", "content": SYSTEM_PROMPT})
        _plan_msgs.append({"role": "user", "content": planning_msg})
        resp = await litellm.acompletion(
            model=LITELLM_MODEL, max_tokens=512, temperature=0.0, messages=_plan_msgs,
        )
        _plan_in_tok  = (getattr(resp.usage, "prompt_tokens",    0) or 0) if resp.usage else 0
        _plan_out_tok = (getattr(resp.usage, "completion_tokens", 0) or 0) if resp.usage else 0
        _charge(LITELLM_MODEL, _plan_in_tok, _plan_out_tok, "plan")
        text = (resp.choices[0].message.content or "").strip()
        text = text.removeprefix("```json").removeprefix("```").removesuffix("```").strip()
        # Extract just the JSON object — handles trailing text / explanations after the closing brace
        _j_start = text.find("{")
        _j_end   = text.rfind("}") + 1
        if _j_start == -1 or _j_end == 0:
            raise ValueError("No JSON object found in plan response")
        plan = json.loads(text[_j_start:_j_end])
        # Validate plan structure
        _plan_errors = []
        if not isinstance(plan.get("goal"), str) or not plan["goal"].strip():
            _plan_errors.append("'goal' must be a non-empty string")
        if not isinstance(plan.get("steps"), list) or not plan["steps"]:
            _plan_errors.append("'steps' must be a non-empty list")
        else:
            for _i, _step in enumerate(plan["steps"]):
                if not isinstance(_step.get("id"), int):
                    _plan_errors.append(f"step[{_i}].id must be an integer")
                if not isinstance(_step.get("description"), str) or not _step["description"].strip():
                    _plan_errors.append(f"step[{_i}].description must be a non-empty string")
        if _plan_errors:
            print(f"[plan] Warning: plan validation failed ({'; '.join(_plan_errors)}) — running in direct mode.",
                  file=sys.stderr)
            return None
        plan["steps"] = plan["steps"][:MAX_PLAN_STEPS]
        return plan
    except Exception as exc:
        print(f"[plan] Warning: could not generate plan: {exc} — running in direct mode.",
              file=sys.stderr)
        return None


{% endif %}
