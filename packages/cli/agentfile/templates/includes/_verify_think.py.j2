{% if has_verifier %}
async def _verify_step(
    goal: str,
    tool_name: str,
    tool_args: dict,
    tool_result: str,
) -> tuple[bool, str, int, int]:
    """
    Call the verifier LLM with a compressed context.
    Returns (ok, reason, input_tokens, output_tokens).
    Falls back to ok=True on any verifier error so it never blocks the main agent.
    """
    prompt = (
        f"OVERALL GOAL: {goal}\n\n"
        f"TOOL CALLED: {tool_name}\n"
        f"TOOL ARGS: {json.dumps(tool_args)[:300]}\n"
        f"TOOL RESULT: {tool_result[:600]}\n\n"
        "This is ONE step in a multi-step process. "
        "Did this specific tool call execute successfully and produce useful output? "
        "Do NOT check whether the overall goal is fully achieved yet — only judge this single step.\n"
        'Reply ONLY with JSON: {"ok": true or false, "reason": "one sentence"}'
    )

    try:
        resp = await litellm.acompletion(
            model=_VERIFIER_LITELLM_MODEL,
            messages=[{"role": "user", "content": prompt}],
            max_tokens=VERIFIER_MAX_TOKENS,
            temperature=0,
        )
        text    = (resp.choices[0].message.content or "").strip()
        in_tok  = getattr(resp.usage, "prompt_tokens", 0) or 0
        out_tok = getattr(resp.usage, "completion_tokens", 0) or 0
        _charge(_VERIFIER_LITELLM_MODEL, in_tok, out_tok, "verifier")
        # Strip optional markdown fences the model may add
        text = text.removeprefix("```json").removeprefix("```").removesuffix("```").strip()
        parsed = json.loads(text)
        return bool(parsed.get("ok", True)), str(parsed.get("reason", "")), in_tok, out_tok
    except Exception as exc:
        print(f"[verify] Warning: verifier error: {exc}", file=sys.stderr)
        return True, f"verifier error: {exc}", 0, 0


