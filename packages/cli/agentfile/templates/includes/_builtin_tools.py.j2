def _exec_builtin_tool(fn_name: str, fn_args: dict) -> str:
    """Dispatch a builtin tool call. Returns result string."""
{% if has_builtin_bash %}
    if fn_name == "bash":
        return _builtin_bash_exec(
            fn_args.get("command", ""),
            timeout=int(fn_args.get("timeout", 60)),
            working_dir=str(fn_args.get("working_dir", "/app")),
        )
{% endif %}
{% if has_builtin_filesystem %}
    if fn_name == "read_file":
        return _builtin_read_file(
            fn_args.get("path", ""),
            offset=int(fn_args.get("offset", 0)),
            limit=int(fn_args.get("limit", 5000)),
        )
    if fn_name == "write_file":
        return _builtin_write_file(fn_args.get("path", ""), fn_args.get("content", ""))
    if fn_name == "list_dir":
        return _builtin_list_dir(
            fn_args.get("path", "."),
            recursive=bool(fn_args.get("recursive", False)),
        )
{% endif %}
{% if has_builtin_memory %}
    if fn_name == "memory_save":
        return _builtin_memory_save(fn_args.get("content", ""), category=fn_args.get("category", "facts"))
    if fn_name == "memory_search":
        return _builtin_memory_search(fn_args.get("query", ""))
    if fn_name == "memory_recall":
        return _builtin_memory_recall(date=fn_args.get("date", ""))
    if fn_name == "memory_summary":
        return _builtin_memory_summary()
{% endif %}
{% if has_builtin_scheduler %}
    if fn_name == "schedule_create":
        return _builtin_schedule_create(
            fn_args.get("description", ""),
            time_str=fn_args.get("time", ""),
            recurring=bool(fn_args.get("recurring", False)),
            cron=fn_args.get("cron", ""),
            channel=fn_args.get("channel", "stdout"),
        )
    if fn_name == "schedule_list":
        return _builtin_schedule_list()
    if fn_name == "schedule_cancel":
        return _builtin_schedule_cancel(fn_args.get("schedule_id", ""))
{% endif %}
{% if has_builtin_web_search %}
    if fn_name == "web_search":
        return _builtin_web_search(fn_args.get("query", ""), max_results=int(fn_args.get("max_results", 5)))
{% endif %}
{% if has_builtin_web_browse %}
    if fn_name == "web_browse":
        return _builtin_web_browse(fn_args.get("url", ""), max_chars=int(fn_args.get("max_chars", 10000)))
{% endif %}
{% if has_builtin_notify %}
    if fn_name == "notify":
        return _builtin_notify(fn_args.get("message", ""), channel=fn_args.get("channel", "stdout"), webhook_url=fn_args.get("webhook_url", ""))
{% endif %}
{% if has_builtin_ask_user %}
    if fn_name == "ask_user":
        return _builtin_ask_user(fn_args.get("question", ""))
{% endif %}
{% if has_builtin_sub_agent %}
    if fn_name in ("sub_agent", "sub_agents_parallel"):
        # sub_agent/sub_agents_parallel are async — dispatched directly from _run_turn
        return "[error] sub_agent tools must be called via async dispatch"
{% endif %}
{% if has_builtin_code_interpreter %}
    if fn_name == "code_interpreter":
        return _builtin_code_interpreter(fn_args.get("code", ""), timeout=int(fn_args.get("timeout", 30)))
{% endif %}
    return f"Error: unknown builtin tool '{fn_name}'"

{% endif %}
