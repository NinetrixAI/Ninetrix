{% if has_builtin_web_search %}
# ── Web Search (DuckDuckGo HTML scrape, no API key) ─────────────────────────
import urllib.request as _urllib_req
import urllib.parse as _urllib_parse
import html as _html_mod


def _builtin_web_search(query: str, max_results: int = 5) -> str:
    """Search the web via DuckDuckGo and return results."""
    try:
        encoded = _urllib_parse.quote_plus(query)
        url = f"https://html.duckduckgo.com/html/?q={encoded}"
        req = _urllib_req.Request(url, headers={"User-Agent": "Mozilla/5.0 (compatible; NinetrixAgent/1.0)"})
        with _urllib_req.urlopen(req, timeout=15) as resp:
            raw = resp.read().decode("utf-8", errors="replace")
        # Parse result snippets from HTML
        results = []
        parts = raw.split('class="result__a"')
        for part in parts[1:max_results + 1]:
            # Extract title
            title_end = part.find("</a>")
            title_start = part.find(">") + 1
            title = _html_mod.unescape(part[title_start:title_end]).strip() if title_end > title_start else ""
            # Extract URL
            href_start = part.find('href="')
            href = ""
            if href_start != -1:
                href_end = part.find('"', href_start + 6)
                href = part[href_start + 6:href_end]
                if href.startswith("//duckduckgo.com/l/?uddg="):
                    href = _urllib_parse.unquote(href.split("uddg=")[1].split("&")[0])
            # Extract snippet
            snippet = ""
            snip_marker = 'class="result__snippet"'
            snip_idx = part.find(snip_marker)
            if snip_idx != -1:
                snip_start = part.find(">", snip_idx) + 1
                snip_end = part.find("</", snip_start)
                snippet = _html_mod.unescape(part[snip_start:snip_end]).strip()
            if title:
                results.append(f"**{title}**\n{href}\n{snippet}")
        if not results:
            return f"No results found for: {query}"
        return "\n\n".join(results)
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


_BUILTIN_WEB_SEARCH_DEF = {
    "type": "function",
    "function": {
        "name": "web_search",
        "description": "Search the web using DuckDuckGo. Returns titles, URLs, and snippets. No API key required.",
        "parameters": {
            "type": "object",
            "required": ["query"],
            "properties": {
                "query": {"type": "string", "description": "Search query"},
                "max_results": {"type": "integer", "description": "Max results to return (default: 5)", "default": 5}
            }
        }
    }
}
