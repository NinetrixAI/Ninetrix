# ── Web Browse (fetch URL, extract text) ─────────────────────────────────────
import urllib.request as _urllib_req


def _builtin_web_browse(url: str, max_chars: int = 10000) -> str:
    """Fetch a URL and return extracted text content."""
    try:
        req = _urllib_req.Request(url, headers={"User-Agent": "Mozilla/5.0 (compatible; NinetrixAgent/1.0)"})
        with _urllib_req.urlopen(req, timeout=20) as resp:
            raw = resp.read().decode("utf-8", errors="replace")
        # Strip HTML tags for a basic text extraction
        import re as _re_browse
        text = _re_browse.sub(r"<script[^>]*>.*?</script>", "", raw, flags=_re_browse.DOTALL | _re_browse.IGNORECASE)
        text = _re_browse.sub(r"<style[^>]*>.*?</style>", "", text, flags=_re_browse.DOTALL | _re_browse.IGNORECASE)
        text = _re_browse.sub(r"<[^>]+>", " ", text)
        text = _re_browse.sub(r"\s+", " ", text).strip()
        if len(text) > max_chars:
            text = text[:max_chars] + f"\n... (truncated, {len(text)} total chars)"
        return text if text else "(empty page)"
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


_BUILTIN_WEB_BROWSE_DEF = {
    "type": "function",
    "function": {
        "name": "web_browse",
        "description": "Fetch a URL and extract its text content. Strips HTML tags. Good for reading articles, docs, and web pages.",
        "parameters": {
            "type": "object",
            "required": ["url"],
            "properties": {
                "url": {"type": "string", "description": "The URL to fetch"},
                "max_chars": {"type": "integer", "description": "Max characters to return (default: 10000)", "default": 10000}
            }
        }
    }
}
