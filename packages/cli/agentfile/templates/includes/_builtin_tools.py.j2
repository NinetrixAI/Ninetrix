# ── Notify (send message to user) ───────────────────────────────────────────
import urllib.request as _urllib_req


def _builtin_notify(message: str, channel: str = "stdout", webhook_url: str = "") -> str:
    """Send a notification to the user."""
    try:
        if channel == "stdout":
            print(f"\n🔔 NOTIFICATION: {message}\n", flush=True)
            return f"Notification sent to stdout: {message[:100]}"
        elif channel == "webhook" and webhook_url:
            data = json.dumps({"text": message, "agent_id": AGENT_ID}).encode()
            req = _urllib_req.Request(
                webhook_url,
                data=data,
                headers={"Content-Type": "application/json"},
                method="POST",
            )
            with _urllib_req.urlopen(req, timeout=10) as resp:
                return f"Notification sent to webhook ({resp.status}): {message[:100]}"
        else:
            print(f"\n🔔 NOTIFICATION: {message}\n", flush=True)
            return f"Notification sent: {message[:100]}"
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


