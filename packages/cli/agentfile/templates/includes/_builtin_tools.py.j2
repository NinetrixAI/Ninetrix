# ── Sub Agent v2 (agentic loop with tool access) ─────────────────────────────

_SUB_AGENT_MAX_CONCURRENT = 5   # hard cap on parallel sub-agents
_SUB_AGENT_TIMEOUT = 120        # per sub-agent timeout in seconds


async def _builtin_sub_agent(
    task: str,
    tools: list | None = None,
    model: str = "",
    max_turns: int = 5,
    max_tokens: int = 4096,
    label: str = "",
    *,
    _parent_sessions: dict | None = None,
    _parent_tool_defs: list | None = None,
{% if has_composio_tools %}
    _composio_toolset=None,
    _composio_tool_names: set | None = None,
{% endif %}
) -> str:
    """Spawn a sub-agent with its own agentic loop, tool access, and tracing.

    Args:
        task:   The task description for the sub-agent.
        tools:  Tool names the sub-agent can use. [] or None = text-only.
                ["*"] = all parent tools minus blocked ones.
        model:  Override model (default: same as parent).
        max_turns: Max agentic loop turns (default: 5, max: 20).
        max_tokens: Max output tokens per LLM call.
        label:  Human-readable label for traces (e.g. "researcher").
    """
    _effective_tools = tools or []
    _effective_max_turns = min(max(1, max_turns), 20)
    _label = label or f"sub_{uuid.uuid4().hex[:6]}"
    _sub_trace_id = f"sub_{uuid.uuid4().hex[:12]}"
    _sub_agent_id = f"{AGENT_ID}:{_label}"

    print(f"[sub_agent] Spawning '{_label}' (tools={_effective_tools}, max_turns={_effective_max_turns})", flush=True)

    # Post transfer-started event for dashboard tracing
    _post_runner_event("agent_transfer_started", {
        "thread_id": THREAD_ID,
        "from": AGENT_ID,
        "to": _sub_agent_id,
        "message_preview": task[:200],
    })

    # Create sub-agent checkpointer (links to parent via parent_trace_id)
    sub_cp = None
    if _SAAS_PERSIST:
        sub_cp = _SaaSCheckpointer(
            thread_id=THREAD_ID,
            trace_id=_sub_trace_id,
            parent_trace_id=TRACE_ID,
            agent_id=_sub_agent_id,
        )
    _start_t = time.perf_counter()

    try:
        result = await asyncio.wait_for(
            _sub_agent_loop(
                task=task,
                tools=_effective_tools,
                sessions_by_tool=_parent_sessions or {},
                tool_definitions=_parent_tool_defs or [],
{% if has_composio_tools %}
                composio_toolset=_composio_toolset,
                composio_tool_names=_composio_tool_names or set(),
{% endif %}
                model=model,
                max_turns=_effective_max_turns,
                max_tokens=max_tokens,
                label=_label,
                sub_cp=sub_cp,
            ),
            timeout=_SUB_AGENT_TIMEOUT,
        )
    except asyncio.TimeoutError:
        result = f"[sub_agent] '{_label}' timed out after {_SUB_AGENT_TIMEOUT}s"
    except BudgetExceededError:
        result = f"[sub_agent] '{_label}' exceeded budget"
    except Exception as exc:
        result = f"[sub_agent error] {type(exc).__name__}: {exc}"

    _elapsed_ms = int((time.perf_counter() - _start_t) * 1000)
    _is_error = result.startswith("[sub_agent") and ("error" in result or "timed out" in result or "exceeded" in result)

    # Post transfer-completed/failed event
    _event_type = "agent_transfer_failed" if _is_error else "agent_transfer_completed"
    _post_runner_event(_event_type, {
        "thread_id": THREAD_ID,
        "from": AGENT_ID,
        "to": _sub_agent_id,
        "duration_ms": _elapsed_ms,
        **({"error": "sub_agent_error", "detail": result[:500]} if _is_error else {"result_preview": result[:200]}),
    })

    _dur_str = f"{_elapsed_ms}ms" if _elapsed_ms < 1000 else f"{_elapsed_ms / 1000:.1f}s"
    print(f"[sub_agent] '{_label}' completed ({_dur_str}): {result[:150].replace(chr(10), ' ')}", flush=True)
    return result


async def _builtin_sub_agents_parallel(
    tasks: list,
    max_concurrent: int = 3,
    *,
    _parent_sessions: dict | None = None,
    _parent_tool_defs: list | None = None,
{% if has_composio_tools %}
    _composio_toolset=None,
    _composio_tool_names: set | None = None,
{% endif %}
) -> str:
    """Run multiple sub-agents in parallel and collect results."""
    if not tasks:
        return "[error] No tasks provided"

    _effective_max = min(max(1, max_concurrent), _SUB_AGENT_MAX_CONCURRENT)
    _sem = asyncio.Semaphore(_effective_max)
    print(f"[sub_agents_parallel] Spawning {len(tasks)} sub-agents (max_concurrent={_effective_max})", flush=True)

    async def _run_one(spec: dict) -> tuple[str, str]:
        async with _sem:
            _lbl = spec.get("label", "")
            _result = await _builtin_sub_agent(
                task=spec.get("task", ""),
                tools=spec.get("tools"),
                model=spec.get("model", ""),
                max_turns=int(spec.get("max_turns", 5)),
                max_tokens=int(spec.get("max_tokens", 4096)),
                label=_lbl,
                _parent_sessions=_parent_sessions,
                _parent_tool_defs=_parent_tool_defs,
{% if has_composio_tools %}
                _composio_toolset=_composio_toolset,
                _composio_tool_names=_composio_tool_names,
{% endif %}
            )
            return _lbl or "sub", _result

    results = await asyncio.gather(
        *[_run_one(spec) for spec in tasks],
        return_exceptions=True,
    )

    parts = []
    for i, r in enumerate(results):
        _lbl = tasks[i].get("label", f"sub_{i}")
        if isinstance(r, Exception):
            parts.append(f"[{_lbl}]: Error: {r}")
        else:
            parts.append(f"[{r[0]}]: {r[1]}")

    merged = "\n\n---\n\n".join(parts)
    print(f"[sub_agents_parallel] All {len(tasks)} sub-agents completed", flush=True)
    return merged


