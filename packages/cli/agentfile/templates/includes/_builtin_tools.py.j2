{% if has_builtin_ask_user %}
# ── Ask User (pause and wait for input) ──────────────────────────────────────

def _builtin_ask_user(question: str) -> str:
    """Pause and ask the user a question. Blocks until they respond."""
    try:
        print(f"\n❓ {question}", flush=True)
        answer = input("> ").strip()
        return answer if answer else "(no answer)"
    except (KeyboardInterrupt, EOFError):
        return "(user cancelled)"
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


