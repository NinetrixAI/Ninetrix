# ── Memory (daily markdown files) ────────────────────────────────────────────
import os as _os
from datetime import datetime as _mem_dt, timezone as _mem_tz

_MEMORY_DIR = _os.environ.get("AGENTFILE_MEMORY_DIR", "/app/memory")
_os.makedirs(_MEMORY_DIR, exist_ok=True)


def _memory_today_path() -> str:
    return _os.path.join(_MEMORY_DIR, _mem_dt.now(_mem_tz.utc).strftime("%Y-%m-%d") + ".md")


def _builtin_memory_save(content: str, category: str = "facts") -> str:
    """Append a memory entry to today's file under the given category."""
    try:
        path = _memory_today_path()
        today = _mem_dt.now(_mem_tz.utc).strftime("%Y-%m-%d")
        existing = ""
        if _os.path.exists(path):
            with open(path, "r") as f:
                existing = f.read()
        if not existing.strip():
            existing = f"# {today}\n"
        header = f"\n## {category.title()}\n"
        if header.strip() not in existing:
            existing += header
        timestamp = _mem_dt.now(_mem_tz.utc).strftime("%H:%M")
        existing += f"- [{timestamp}] {content}\n"
        with open(path, "w") as f:
            f.write(existing)
        return f"Saved to memory ({category}): {content[:100]}"
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


def _builtin_memory_search(query: str) -> str:
    """Full-text search across all memory files. Returns matching sections."""
    try:
        results = []
        query_lower = query.lower()
        if not _os.path.exists(_MEMORY_DIR):
            return "No memories found."
        files = sorted(
            [f for f in _os.listdir(_MEMORY_DIR) if f.endswith(".md")],
            reverse=True
        )
        for fname in files[:90]:
            fpath = _os.path.join(_MEMORY_DIR, fname)
            with open(fpath, "r") as f:
                content = f.read()
            for line in content.split("\n"):
                if query_lower in line.lower():
                    results.append(f"[{fname}] {line.strip()}")
        if not results:
            return f"No memories matching '{query}'."
        return "\n".join(results[:50])
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


def _builtin_memory_recall(date: str = "") -> str:
    """Read a specific day's memory file, or today's if no date given."""
    try:
        if not date:
            date = _mem_dt.now(_mem_tz.utc).strftime("%Y-%m-%d")
        path = _os.path.join(_MEMORY_DIR, f"{date}.md")
        if not _os.path.exists(path):
            return f"No memories for {date}."
        with open(path, "r") as f:
            return f.read()
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


def _builtin_memory_summary() -> str:
    """Read the rolling summary file, or generate one from recent days."""
    try:
        summary_path = _os.path.join(_MEMORY_DIR, "summary.md")
        if _os.path.exists(summary_path):
            with open(summary_path, "r") as f:
                return f.read()
        # No summary yet — return last 3 days
        files = sorted(
            [f for f in _os.listdir(_MEMORY_DIR) if f.endswith(".md") and f != "summary.md"],
            reverse=True
        )
        if not files:
            return "No memories yet."
        parts = []
        for fname in files[:3]:
            fpath = _os.path.join(_MEMORY_DIR, fname)
            with open(fpath, "r") as f:
                parts.append(f.read())
        return "\n---\n".join(parts)
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


