{% if has_builtin_filesystem %}
import os as _os

def _builtin_read_file(path: str, offset: int = 0, limit: int = 5000) -> str:
    """Read a file and return its contents."""
    try:
        with open(path, "r") as f:
            lines = f.readlines()
        selected = lines[offset:offset + limit]
        numbered = [f"{offset + i + 1}: {line}" for i, line in enumerate(selected)]
        result = "".join(numbered)
        if len(lines) > offset + limit:
            result += f"\n... ({len(lines) - offset - limit} more lines)"
        return result
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


def _builtin_write_file(path: str, content: str) -> str:
    """Write content to a file, creating directories if needed."""
    try:
        _os.makedirs(_os.path.dirname(path) or ".", exist_ok=True)
        with open(path, "w") as f:
            f.write(content)
        return f"Written {len(content)} bytes to {path}"
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


def _builtin_list_dir(path: str = ".", recursive: bool = False) -> str:
    """List directory contents."""
    try:
        if recursive:
            entries = []
            for root, dirs, files in _os.walk(path):
                for name in dirs + files:
                    entries.append(_os.path.join(root, name))
            return "\n".join(sorted(entries)[:500])
        else:
            entries = sorted(_os.listdir(path))
            return "\n".join(entries)
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


