{% if has_builtin_scheduler %}
# ── Scheduler (persistent reminders & recurring tasks) ───────────────────────
import os as _os
import threading as _threading
from datetime import datetime as _sched_dt, timezone as _sched_tz, timedelta as _sched_td

_SCHEDULES_FILE = _os.path.join(
    _os.environ.get("AGENTFILE_MEMORY_DIR", "/app/memory"),
    "schedules.json"
)
_sched_lock = _threading.Lock()

# Queue for fired reminders — the main conversation loop drains this
_reminder_queue: list[str] = []
_reminder_queue_lock = _threading.Lock()


def _get_local_tz() -> _sched_tz:
    """Get the machine's local timezone offset."""
    try:
        local_offset = _sched_dt.now(_sched_tz.utc).astimezone().utcoffset()
        if local_offset is not None:
            return _sched_tz(local_offset)
    except Exception:
        pass
    return _sched_tz.utc


def _now_local() -> _sched_dt:
    """Get current time in the machine's local timezone."""
    return _sched_dt.now(_get_local_tz())


def _load_schedules() -> list:
    try:
        with _sched_lock:
            if _os.path.exists(_SCHEDULES_FILE):
                with open(_SCHEDULES_FILE, "r") as f:
                    return json.loads(f.read())
    except Exception:
        pass
    return []


def _save_schedules(schedules: list) -> None:
    with _sched_lock:
        _os.makedirs(_os.path.dirname(_SCHEDULES_FILE) or ".", exist_ok=True)
        with open(_SCHEDULES_FILE, "w") as f:
            f.write(json.dumps(schedules, indent=2))


def _parse_schedule_time(time_str: str) -> _sched_dt | None:
    """Parse various time formats into a timezone-aware datetime."""
    # Try ISO format first (with timezone info)
    for fmt in ("%Y-%m-%dT%H:%M:%S%z", "%Y-%m-%dT%H:%M:%SZ"):
        try:
            dt = _sched_dt.strptime(time_str, fmt)
            if fmt.endswith("Z"):
                dt = dt.replace(tzinfo=_sched_tz.utc)
            return dt
        except ValueError:
            continue
    # Naive formats → assume LOCAL timezone
    local_tz = _get_local_tz()
    for fmt in ("%Y-%m-%dT%H:%M:%S", "%Y-%m-%d %H:%M:%S", "%Y-%m-%d %H:%M",
                "%H:%M:%S", "%H:%M"):
        try:
            dt = _sched_dt.strptime(time_str, fmt)
            if fmt in ("%H:%M:%S", "%H:%M"):
                # Time-only → today's date in local tz
                today = _now_local()
                dt = dt.replace(year=today.year, month=today.month, day=today.day)
            dt = dt.replace(tzinfo=local_tz)
            return dt
        except ValueError:
            continue
    # Relative: "in Xm", "in Xh", "in X minutes"
    import re as _re_sched
    m = _re_sched.match(r"in\s+(\d+)\s*(m|min|mins|minutes?|h|hrs?|hours?|s|sec|secs?|seconds?)", time_str.lower().strip())
    if m:
        val = int(m.group(1))
        unit = m.group(2)[0]  # m, h, or s
        delta = {"s": _sched_td(seconds=val), "m": _sched_td(minutes=val), "h": _sched_td(hours=val)}[unit]
        return _now_local() + delta
    return None


def _cron_matches_now(cron_expr: str, now: _sched_dt) -> bool:
    """Simple cron matching: 'minute hour day month weekday'."""
    parts = cron_expr.strip().split()
    if len(parts) != 5:
        return False
    fields = [now.minute, now.hour, now.day, now.month, now.weekday()]
    # weekday: cron uses 0=Sun, python uses 0=Mon → convert
    fields[4] = (fields[4] + 1) % 7
    for cron_val, actual_val in zip(parts, fields):
        if cron_val == "*":
            continue
        try:
            if int(cron_val) != actual_val:
                return False
        except ValueError:
            return False
    return True


# ── Background scheduler thread ──────────────────────────────────────────────
_scheduler_started = False


def _scheduler_loop():
    """Background thread: checks schedules every 5 seconds, fires due reminders."""
    while True:
        try:
            time.sleep(5)
            schedules = _load_schedules()
            now = _now_local()
            changed = False

            for entry in schedules:
                if entry.get("status") != "active":
                    continue

                should_fire = False

                if entry.get("recurring") and entry.get("cron"):
                    should_fire = _cron_matches_now(entry["cron"], now)
                    # Prevent double-fire within same minute
                    last_fired = entry.get("last_fired", "")
                    this_minute = now.strftime("%Y-%m-%dT%H:%M")
                    if should_fire and last_fired == this_minute:
                        should_fire = False
                    if should_fire:
                        entry["last_fired"] = this_minute
                        changed = True
                else:
                    # One-time reminder — compare in UTC to avoid tz confusion
                    fire_at = _parse_schedule_time(entry.get("time", ""))
                    if fire_at:
                        # Normalize both to UTC for comparison
                        now_utc = _sched_dt.now(_sched_tz.utc)
                        fire_utc = fire_at.astimezone(_sched_tz.utc)
                        if now_utc >= fire_utc:
                            should_fire = True
                            entry["status"] = "fired"
                            changed = True

                if should_fire:
                    msg = entry.get("description", "Reminder")
                    # Push to reminder queue — the main loop will inject it
                    with _reminder_queue_lock:
                        _reminder_queue.append(msg)
                    # Also print immediately in case the agent is idle
                    print(
                        f"\n{'='*60}\n"
                        f"\U0001f514 REMINDER: {msg}\n"
                        f"{'='*60}\n",
                        flush=True,
                    )

            if changed:
                _save_schedules(schedules)
        except Exception as _sched_exc:
            print(f"[scheduler] Error: {_sched_exc}", file=sys.stderr, flush=True)


def _drain_reminders() -> list[str]:
    """Drain all pending reminders from the queue. Called from the main loop."""
    with _reminder_queue_lock:
        items = list(_reminder_queue)
        _reminder_queue.clear()
    return items


def _start_scheduler():
    """Start the background scheduler thread (once)."""
    global _scheduler_started
    if _scheduler_started:
        return
    _scheduler_started = True
    t = _threading.Thread(target=_scheduler_loop, daemon=True, name="builtin-scheduler")
    t.start()
    _tz_name = _now_local().strftime("%Z") or str(_get_local_tz())
    print(f"[scheduler] Background scheduler started (checks every 5s, timezone: {_tz_name})", file=sys.stderr, flush=True)


# Auto-start the scheduler when the module loads
_start_scheduler()


def _builtin_schedule_create(
    description: str,
    time_str: str,
    recurring: bool = False,
    cron: str = "",
    channel: str = "stdout",
) -> str:
    """Create a scheduled reminder or recurring task."""
    try:
        # Validate time for one-time reminders
        if not recurring:
            parsed = _parse_schedule_time(time_str)
            if parsed is None:
                return (
                    f"[error] Could not parse time: '{time_str}'. "
                    "Use ISO format (2026-03-22T13:20:00Z) or relative (in 5m, in 2h)."
                )
            # Store the absolute ISO time so the scheduler can compare
            time_str = parsed.isoformat()

        schedules = _load_schedules()
        entry = {
            "id": f"sched_{uuid.uuid4().hex[:8]}",
            "description": description,
            "time": time_str,
            "recurring": recurring,
            "cron": cron,
            "channel": channel,
            "status": "active",
            "created_at": _sched_dt.now(_sched_tz.utc).isoformat(),
        }
        schedules.append(entry)
        _save_schedules(schedules)
        kind = "recurring task" if recurring else "reminder"
        if not recurring:
            return f"Created {kind}: '{description}' — will fire at {time_str} (id: {entry['id']})"
        else:
            return f"Created {kind}: '{description}' — cron: {cron} (id: {entry['id']})"
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


def _builtin_schedule_list() -> str:
    """List all scheduled reminders and tasks."""
    try:
        schedules = _load_schedules()
        if not schedules:
            return "No scheduled reminders or tasks."
        lines = []
        for s in schedules:
            status = s.get("status", "active")
            kind = "recurring" if s.get("recurring") else "one-time"
            lines.append(f"- [{status}] {s['id']}: {s['description']} ({kind}, {s['time']})")
        return "\n".join(lines)
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


def _builtin_schedule_cancel(schedule_id: str) -> str:
    """Cancel a scheduled reminder or task by ID."""
    try:
        schedules = _load_schedules()
        for s in schedules:
            if s["id"] == schedule_id:
                s["status"] = "cancelled"
                _save_schedules(schedules)
                return f"Cancelled schedule: {schedule_id}"
        return f"Schedule not found: {schedule_id}"
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


_BUILTIN_SCHEDULE_CREATE_DEF = {
    "type": "function",
    "function": {
        "name": "schedule_create",
        "description": (
            "Create a reminder or recurring task. The reminder WILL fire automatically — "
            "a background thread checks every 5 seconds and injects reminders into the conversation. "
            "Times are in the user's LOCAL timezone. "
            "For one-time: use relative time (e.g. 'in 1m', 'in 5m', 'in 2h') or ISO datetime. "
            "For recurring: set recurring=true and provide a cron expression (e.g. '0 9 * * *')."
