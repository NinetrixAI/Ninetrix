                "time": {"type": "string", "description": "When to fire: ISO datetime (2026-03-22T13:20:00Z), or relative (in 5m, in 1h, in 30s)"},
                "recurring": {"type": "boolean", "description": "Whether this repeats (default: false)", "default": False},
                "cron": {"type": "string", "description": "Cron expression for recurring tasks (e.g. '0 9 * * *' for daily at 9am)", "default": ""},
                "channel": {"type": "string", "description": "Delivery channel: stdout, webhook (default: stdout)", "default": "stdout"}
            }
        }
    }
}

_BUILTIN_SCHEDULE_LIST_DEF = {
    "type": "function",
