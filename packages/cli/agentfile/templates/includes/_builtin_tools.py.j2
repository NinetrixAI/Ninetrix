{% if has_builtin_code_interpreter %}
# ── Code Interpreter (sandboxed Python execution) ───────────────────────────

def _builtin_code_interpreter(code: str, timeout: int = 30) -> str:
    """Run Python code in a subprocess and return stdout + stderr."""
    try:
        result = _subprocess.run(
            [sys.executable, "-c", code],
            capture_output=True,
            text=True,
            timeout=timeout,
            cwd="/app",
        )
        output_parts = []
        if result.stdout:
            output_parts.append(result.stdout)
        if result.stderr:
            output_parts.append(f"[stderr] {result.stderr}")
        output_parts.append(f"[exit_code: {result.returncode}]")
        return "\n".join(output_parts).strip()
    except _subprocess.TimeoutExpired:
        return f"[error] Code execution timed out after {timeout}s"
    except Exception as exc:
        return f"[error] {type(exc).__name__}: {exc}"


