# ── Agentic loop ──────────────────────────────────────────────────────────────

async def _run_turn(
    user_input: str,
    sessions_by_tool: dict,
    tool_definitions: list,
{% if has_composio_tools %}
    composio_toolset=None,
    composio_tool_names: set = set(),
{% endif %}
{% if has_planned_execution or has_verifier %}
    plan_goal: str = "",
{% endif %}
    result_collector: list | None = None,
    thread_id: str = "",
    saas_cp=None,           # _SaaSCheckpointer | None — transparent SaaS persistence
    prior_messages: list | None = None,   # chat session history to restore
    messages_out:   list | None = None,   # caller receives final messages here
    reasoning_hint: str = "",  # ephemeral pre-turn reasoning; injected as system msg, never stored
) -> None:
    messages: list = []
    if SYSTEM_PROMPT:
        messages.append({"role": "system", "content": SYSTEM_PROMPT})
    if reasoning_hint:
        # Inject as a second ephemeral system message — never stored in history,
        # so it doesn't pollute the user message or subsequent turns.
        messages.append({"role": "system", "content": f"[Pre-turn reasoning — internal scratchpad]\n{reasoning_hint}"})
    # Restore prior conversation history (in-memory session context)
    if prior_messages:
        for _hm in prior_messages:
            if _hm.get("role") != "system":
                messages.append(_hm)
    messages.append({"role": "user", "content": user_input})
    # Stamp the user message NOW so the user→assistant delta captures LLM latency.
    if saas_cp is not None:
        saas_cp.record("user")

{% if has_planned_execution %}
    _no_tool_streak = 0   # consecutive turns with no tool call (plan mode only)
{% endif %}
    _scp_in = _scp_out = 0  # per-turn token counts for saas_cp telemetry
    for _turn in range(MAX_TURNS):
        await _rate_limit_wait()
        try:
            response = await litellm.acompletion(
                model=LITELLM_MODEL,
                messages=_trim_messages(messages),
                tools=tool_definitions or None,
                max_tokens=MAX_TOKENS,
                temperature=TEMP,
                num_retries=3,
            )
        except litellm.AuthenticationError:
            _key_var = _API_KEY_VARS.get(PROVIDER, "API key")
            print(f"Error: Authentication failed. Check your {_key_var} for provider '{PROVIDER}'.",
                  file=sys.stderr, flush=True)
            return
        except litellm.BadRequestError as _br_err:
            _err_msg = str(_br_err)
            # Strip ANSI codes and LiteLLM internal noise from the message
            _err_msg = re.sub(r"\x1b\[[0-9;]*m", "", _err_msg)
            _err_msg = re.sub(r"Give Feedback / Get Help.*$", "", _err_msg, flags=re.MULTILINE).strip()
            _err_msg = re.sub(r"LiteLLM\.Info:.*$", "", _err_msg, flags=re.MULTILINE).strip()
            print(f"Error: {_err_msg}", file=sys.stderr, flush=True)
            return

        choice = response.choices[0]
        msg    = choice.message
        # Always extract token counts — needed for both telemetry and budget enforcement.
        _scp_in  = (getattr(response.usage, "prompt_tokens",    0) or 0) if response.usage else 0
        _scp_out = (getattr(response.usage, "completion_tokens", 0) or 0) if response.usage else 0
        if saas_cp is not None:
            saas_cp.tokens_used += _scp_in + _scp_out
        _charge(LITELLM_MODEL, _scp_in, _scp_out)  # raises BudgetExceededError if over budget

        _assistant_msg: dict = {
            "role": "assistant",
            "content": msg.content,
            "tool_calls": [
                {
                    "id": tc.id,
                    "type": "function",
                    "function": {"name": tc.function.name, "arguments": tc.function.arguments},
                }
                for tc in (msg.tool_calls or [])
            ] or None,
        }
        messages.append(_assistant_msg)
        if saas_cp is not None:
            saas_cp.record("assistant", in_tok=_scp_in, out_tok=_scp_out)
            saas_cp.step(messages, "in_progress", in_tok=_scp_in, out_tok=_scp_out)

        if choice.finish_reason in ("stop", "end_turn") or not msg.tool_calls:
{% if has_output_type %}
            # Structured output: validate JSON against output_type schema
            if msg.content:
                try:
                    _validated = _validate_output(msg.content)
                    # Replace raw text with clean JSON for downstream consumers
                    _clean_json = json.dumps(_validated)
                    if result_collector is not None:
                        result_collector.append(_clean_json)
                    else:
                        _console.print(_clean_json, markup=False, highlight=False)
                except (json.JSONDecodeError, ValueError) as _parse_err:
                    if _turn < MAX_TURNS - 1 and not getattr(_run_turn, "_output_retried", False):
                        _run_turn._output_retried = True
                        print(f"[output] Validation failed: {_parse_err} — retrying", file=sys.stderr, flush=True)
                        messages.append({"role": "assistant", "content": msg.content})
                        messages.append({"role": "user", "content":
                            f"Your response was not valid JSON matching the required schema. "
                            f"Error: {_parse_err}\n\nPlease respond ONLY with the JSON object."
                        })
                        if saas_cp is not None:
                            saas_cp.record("assistant")
                            saas_cp.record("user")
                        continue
                    else:
                        # Give up — return raw content
                        if result_collector is not None:
                            result_collector.append(msg.content)
                        else:
                            _console.print(msg.content, markup=False, highlight=False)
{% else %}
            if msg.content:
                if result_collector is not None:
                    result_collector.append(msg.content)
                else:
                    _console.print(msg.content, markup=False, highlight=False)
{% endif %}
{% if has_planned_execution %}
            # Plan mode: if no tool was called, the LLM may be mid-execution
            # (wrote intermediate text instead of calling the next tool).
            # Inject a continuation prompt and keep going — but cap at 2
            # consecutive no-tool turns to avoid infinite loops.
            if not msg.tool_calls:
                _no_tool_streak += 1
                if _no_tool_streak < 2 and _turn < MAX_TURNS - 1:
                    _cont_msg: dict = {"role": "user", "content": "Continue. Call the next tool in the plan now."}
                    messages.append(_cont_msg)
                    if saas_cp is not None:
                        saas_cp.record("user")
                    continue
{% endif %}
            if saas_cp is not None:
                saas_cp.step(messages, "idle", in_tok=_scp_in, out_tok=_scp_out)
            if messages_out is not None:
                messages_out[:] = [m for m in messages if m.get("role") != "system"]
            return

        if msg.content:
            if result_collector is None:
                _console.print(msg.content, end="", markup=False, highlight=False)

{% if has_planned_execution %}
        _plan_aborted = False
        if msg.tool_calls:
            _no_tool_streak = 0   # reset — agent is still making progress
{% endif %}
        for tc in (msg.tool_calls or []):
{% if has_planned_execution %}
            if _plan_aborted:
                _rej: dict = {"role": "tool", "tool_call_id": tc.id,
                              "content": "Plan aborted."}
                messages.append(_rej)
                if saas_cp is not None:
                    saas_cp.record("tool")
                continue
{% endif %}
            fn_name = tc.function.name
            try:
                fn_args = json.loads(tc.function.arguments or "{}")
            except json.JSONDecodeError:
                fn_args = {}
{% if agent.governance.human_approval.enabled and agent.governance.human_approval.actions %}
            if _APPROVAL_ENABLED and fn_name in {{ agent.governance.human_approval.actions | tojson }}:
                if saas_cp is not None and _SAAS_PERSIST:
                    _approved = await saas_cp.wait_for_approval(fn_name, fn_args)
                else:
                    _approved = _stdin_approve(fn_name)
                if not _approved:
                    _rejection: dict = {
                        "role": "tool",
                        "tool_call_id": tc.id,
                        "content": "Tool call rejected by human reviewer.",
                    }
                    messages.append(_rejection)
                    if saas_cp is not None:
                        saas_cp.record("tool")
                    continue
{% endif %}
            if result_collector is None:
                _console.print(f"\n  [bold cyan]⚡ {fn_name}[/bold cyan]")
            _args_preview = json.dumps(fn_args, ensure_ascii=False)[:200]
            print(f"[tool] → {fn_name}({_args_preview})", flush=True)
            _tool_t0 = time.perf_counter()
            if fn_name in sessions_by_tool:
                # MCP tool
                session = sessions_by_tool[fn_name]
                try:
                    result = await asyncio.wait_for(
                        session.call_tool(fn_name, fn_args),
                        timeout=TOOL_TIMEOUT,
                    )
                    result_str = _extract_text(result.content)
                except asyncio.TimeoutError:
                    result_str = f"Tool '{fn_name}' timed out after {TOOL_TIMEOUT}s. Increase with AGENTFILE_TOOL_TIMEOUT={TOOL_TIMEOUT + 30}"
                    print(f"[tool] ✗ {fn_name}: timed out after {TOOL_TIMEOUT}s",
                          file=sys.stderr, flush=True)
                except BaseException as exc:
                    if isinstance(exc, (KeyboardInterrupt, SystemExit)):
                        raise
                    result_str = f"Tool error: {type(exc).__name__}: {exc}"
                    print(f"[tool] ✗ {fn_name}: {type(exc).__name__}: {exc}",
                          file=sys.stderr, flush=True)
{% if has_composio_tools %}
            elif fn_name in composio_tool_names and composio_toolset is not None:
                # Composio tool
                result_str, _ = _run_composio_tool(composio_toolset, fn_name, fn_args)
{% endif %}
{% if has_collaborators %}
            elif fn_name == "transfer_to_agent":
                # Delegate to a collaborator agent
                _tid = thread_id or THREAD_ID
                result_str = await _transfer_to_agent(
                    fn_args.get("agent", ""),
                    fn_args.get("message", ""),
                    fn_args.get("context", {}),
                    _tid,
                )
{% if collaborators | length >= 2 %}
            elif fn_name == "transfer_to_agents_parallel":
                # Parallel delegation to multiple agents
                _tid = thread_id or THREAD_ID
                result_str = await _transfer_parallel(fn_args.get("transfers", []), _tid)
{% endif %}
{% endif %}
{% if has_local_tools %}
            elif fn_name in _local_tool_registry.names():
                # Local @Tool Python function
                try:
                    _ltd = _local_tool_registry.get(fn_name)
                    _local_result = _ltd.call(**fn_args)
                    result_str = str(_local_result) if _local_result is not None else "(done)"
                except Exception as _le:
                    result_str = f"Tool error: {type(_le).__name__}: {_le}"
{% endif %}
{% if has_any_builtin %}
            elif fn_name in _BUILTIN_TOOL_NAMES:
                # Builtin tool
                try:
{% if has_builtin_sub_agent %}
                    if fn_name == "sub_agent":
                        result_str = await _builtin_sub_agent(
                            task=fn_args.get("task", ""),
                            tools=fn_args.get("tools"),
                            model=fn_args.get("model", ""),
                            max_turns=int(fn_args.get("max_turns", 5)),
                            max_tokens=int(fn_args.get("max_tokens", 4096)),
                            label=fn_args.get("label", ""),
                            _parent_sessions=sessions_by_tool,
                            _parent_tool_defs=tool_definitions,
{% if has_composio_tools %}
                            _composio_toolset=composio_toolset,
                            _composio_tool_names=composio_tool_names,
{% endif %}
                        )
                    elif fn_name == "sub_agents_parallel":
                        result_str = await _builtin_sub_agents_parallel(
                            tasks=fn_args.get("tasks", []),
                            max_concurrent=int(fn_args.get("max_concurrent", 3)),
                            _parent_sessions=sessions_by_tool,
                            _parent_tool_defs=tool_definitions,
{% if has_composio_tools %}
                            _composio_toolset=composio_toolset,
                            _composio_tool_names=composio_tool_names,
{% endif %}
                        )
                    else:
                        result_str = _exec_builtin_tool(fn_name, fn_args)
{% else %}
                    result_str = _exec_builtin_tool(fn_name, fn_args)
{% endif %}
                except Exception as _be:
                    result_str = f"Tool error: {type(_be).__name__}: {_be}"
{% endif %}
            else:
                result_str = f"Error: tool '{fn_name}' is not available."

            _tool_dur_ms = int((time.perf_counter() - _tool_t0) * 1000)
{% if has_verifier %}
            _is_tool_error = result_str.startswith("Tool error:") or result_str.startswith("Error:")
            if plan_goal and not _is_tool_error:
                _v_ok, _v_reason, _v_in, _v_out = await _verify_step(
                    plan_goal, fn_name, fn_args, result_str
                )
                if result_collector is None:
                    _console.print(f"  [bold {'green' if _v_ok else 'red'}]{'✓' if _v_ok else '✗'}[/] [dim]{_v_reason}[/dim]")
                if not _v_ok:
{% if on_step_failure == "abort" %}
{% if has_planned_execution %}
                    _plan_aborted = True
{% endif %}
                    result_str = f"Step verification failed: {_v_reason}"
{% elif on_step_failure == "retry_once" %}
                    result_str = f"Step failed: {_v_reason}. Please retry or use an alternative approach."
{% else %}
                    pass  # on_step_failure == "continue": logged above, keep going
{% endif %}
{% endif %}
            # Strip lone surrogates, then ASCII-escape any remaining non-ASCII
            # characters. LiteLLM's internal retry/error-handling paths use
            # ASCII encoding; non-ASCII tool results (√, ×, emoji, etc.) cause
            # an InternalServerError that masks the real error. \u221a is still
            # semantically meaningful to the LLM.
            result_str = result_str.encode("utf-8", "replace").decode("utf-8")
            if not result_str.isascii():
                result_str = result_str.encode("ascii", "backslashreplace").decode("ascii")
            _result_preview = result_str[:300].replace("\n", " ")
            _dur_str = f"{_tool_dur_ms}ms" if _tool_dur_ms < 1000 else f"{_tool_dur_ms / 1000:.1f}s"
            if result_str.startswith("Tool error:") or result_str.startswith("Error:"):
                print(f"[tool] ✗ {fn_name} ({_dur_str}): {_result_preview}", file=sys.stderr, flush=True)
            else:
                print(f"[tool] ← {fn_name} ({_dur_str}): {_result_preview}", flush=True)
            _tool_result: dict = {"role": "tool", "tool_call_id": tc.id, "content": result_str}
            messages.append(_tool_result)
            if saas_cp is not None:
                saas_cp.record("tool", duration_ms=_tool_dur_ms)

        if saas_cp is not None:
            saas_cp.step(messages, "in_progress")
{% if has_planned_execution %}
        if _plan_aborted:
            if result_collector is None:
                _console.print("[bold red]✗ Plan aborted:[/bold red] step verification failed.")
            if saas_cp is not None:
                saas_cp.step(messages, "idle", in_tok=_scp_in, out_tok=_scp_out)
            if messages_out is not None:
                messages_out[:] = [m for m in messages if m.get("role") != "system"]
            return
{% endif %}
        continue

    if messages_out is not None:
        messages_out[:] = [m for m in messages if m.get("role") != "system"]
    print(f"[warning] Reached maximum turns ({MAX_TURNS}). Stopping.")


{% if has_builtin_sub_agent %}
# ── Sub-agent agentic loop ────────────────────────────────────────────────────
# A lightweight agentic loop for sub-agents. Runs inside the same container as a
# coroutine — reuses parent's MCP sessions, builtin tools, and budget tracking.
# Each sub-agent gets its own message history, trace_id, and checkpointer.

# Tools that sub-agents must never access (prevent nesting / user interaction)
_SUBAGENT_BLOCKED_TOOLS = {"sub_agent", "sub_agents_parallel", "transfer_to_agent",
                           "transfer_to_agents_parallel", "ask_user"}


def _filter_sub_tools(
    requested: list[str],
    parent_tool_defs: list[dict],
    parent_sessions_by_tool: dict,
) -> tuple[list[dict], dict]:
    """Build filtered tool definitions and session map for a sub-agent.

    Args:
        requested: Tool names requested by the parent. Empty = text-only (no tools).
                   ["*"] = all parent tools minus blocked ones.
        parent_tool_defs: Full tool_definitions list from the parent agent.
        parent_sessions_by_tool: Parent's MCP sessions_by_tool dict.

    Returns:
        (filtered_tool_defs, filtered_sessions) tuple.
    """
    if not requested:
        return [], {}

    use_all = requested == ["*"] or "*" in requested

    filtered_defs: list[dict] = []
    filtered_sessions: dict = {}

    for td in parent_tool_defs:
        fn = td.get("function", {})
        name = fn.get("name", "")
        if name in _SUBAGENT_BLOCKED_TOOLS:
            continue
        if use_all or name in requested:
            filtered_defs.append(td)
            if name in parent_sessions_by_tool:
                filtered_sessions[name] = parent_sessions_by_tool[name]

    return filtered_defs, filtered_sessions


async def _sub_agent_loop(
    task: str,
    tools: list[str],
    sessions_by_tool: dict,
    tool_definitions: list,
{% if has_composio_tools %}
    composio_toolset,
    composio_tool_names: set,
{% endif %}
    model: str = "",
    max_turns: int = 5,
    max_tokens: int = 4096,
    label: str = "",
    sub_cp=None,
) -> str:
    """Run a mini agentic loop for a sub-agent with filtered tool access.

    Returns the final assistant text response.
    """
    sub_model = model or MODEL
    sub_litellm = f"{_PROVIDER_PREFIX.get(PROVIDER, PROVIDER)}/{sub_model}"
    sub_agent_id = f"{AGENT_ID}:{label}" if label else f"{AGENT_ID}:sub"

    # Filter tools for this sub-agent
    sub_tool_defs, sub_sessions = _filter_sub_tools(
        tools, tool_definitions, sessions_by_tool,
    )

    # Build message history
    messages: list = [
        {"role": "system", "content": (
            f"You are a focused sub-agent of '{AGENT_ID}'. "
            "Complete the assigned task thoroughly and return the result. "
            "Be concise but complete. Do not ask for clarification."
        )},
        {"role": "user", "content": task},
    ]
    if sub_cp is not None:
        sub_cp.record("user")

    # If no tools requested, do a single LLM call (v1 compat)
    if not sub_tool_defs:
        try:
            response = await litellm.acompletion(
                model=sub_litellm,
                messages=messages,
                max_tokens=max_tokens,
                temperature=TEMP,
                num_retries=2,
            )
            result_text = response.choices[0].message.content or ""
            _in = getattr(response.usage, "prompt_tokens", 0) or 0
            _out = getattr(response.usage, "completion_tokens", 0) or 0
            _charge(sub_litellm, _in, _out, label="sub_agent")
            if sub_cp is not None:
                sub_cp.tokens_used += _in + _out
                sub_cp.record("assistant", in_tok=_in, out_tok=_out)
                sub_cp.step(messages + [{"role": "assistant", "content": result_text}],
                            "completed", in_tok=_in, out_tok=_out)
            return result_text
        except Exception as exc:
            return f"[sub_agent error] {type(exc).__name__}: {exc}"

    # Full agentic loop with tools
    last_response = ""
    for _turn in range(max_turns):
        await _rate_limit_wait()
        try:
            response = await litellm.acompletion(
                model=sub_litellm,
                messages=_trim_messages(messages),
                tools=sub_tool_defs,
                max_tokens=max_tokens,
                temperature=TEMP,
                num_retries=2,
            )
        except Exception as exc:
            return f"[sub_agent error] {type(exc).__name__}: {exc}"

        choice = response.choices[0]
        msg = choice.message
        _in = (getattr(response.usage, "prompt_tokens", 0) or 0) if response.usage else 0
        _out = (getattr(response.usage, "completion_tokens", 0) or 0) if response.usage else 0
        _charge(sub_litellm, _in, _out, label="sub_agent")
        if sub_cp is not None:
            sub_cp.tokens_used += _in + _out

        _assistant_msg: dict = {
            "role": "assistant",
            "content": msg.content,
            "tool_calls": [
                {"id": tc.id, "type": "function",
                 "function": {"name": tc.function.name, "arguments": tc.function.arguments}}
                for tc in (msg.tool_calls or [])
            ] or None,
        }
        messages.append(_assistant_msg)
        if sub_cp is not None:
            sub_cp.record("assistant", in_tok=_in, out_tok=_out)
            sub_cp.step(messages, "in_progress", in_tok=_in, out_tok=_out)

        # Done — no tool calls
        if choice.finish_reason in ("stop", "end_turn") or not msg.tool_calls:
            last_response = msg.content or ""
            if sub_cp is not None:
                sub_cp.step(messages, "completed", in_tok=_in, out_tok=_out)
            return last_response

        if msg.content:
            print(f"[sub:{label or 'sub'}] {msg.content[:120]}", flush=True)

        # Execute tool calls
        for tc in (msg.tool_calls or []):
            fn_name = tc.function.name
            try:
                fn_args = json.loads(tc.function.arguments or "{}")
            except json.JSONDecodeError:
                fn_args = {}

            print(f"[sub:{label or 'sub'}] ⚡ {fn_name}({json.dumps(fn_args, ensure_ascii=False)[:150]})", flush=True)
            _tool_t0 = time.perf_counter()

            if fn_name in sub_sessions:
                # MCP tool
                try:
                    result = await asyncio.wait_for(
                        sub_sessions[fn_name].call_tool(fn_name, fn_args),
                        timeout=TOOL_TIMEOUT,
                    )
                    result_str = _extract_text(result.content)
                except asyncio.TimeoutError:
                    result_str = f"Tool '{fn_name}' timed out after {TOOL_TIMEOUT}s"
                except BaseException as exc:
                    if isinstance(exc, (KeyboardInterrupt, SystemExit)):
                        raise
                    result_str = f"Tool error: {type(exc).__name__}: {exc}"
{% if has_composio_tools %}
            elif fn_name in composio_tool_names and composio_toolset is not None:
                result_str, _ = _run_composio_tool(composio_toolset, fn_name, fn_args)
{% endif %}
{% if has_local_tools %}
            elif fn_name in _local_tool_registry.names():
                try:
                    _ltd = _local_tool_registry.get(fn_name)
                    _local_result = _ltd.call(**fn_args)
                    result_str = str(_local_result) if _local_result is not None else "(done)"
                except Exception as _le:
                    result_str = f"Tool error: {type(_le).__name__}: {_le}"
{% endif %}
{% if has_any_builtin %}
            elif fn_name in _BUILTIN_TOOL_NAMES and fn_name not in _SUBAGENT_BLOCKED_TOOLS:
                try:
                    result_str = _exec_builtin_tool(fn_name, fn_args)
                except Exception as _be:
                    result_str = f"Tool error: {type(_be).__name__}: {_be}"
{% endif %}
            else:
                result_str = f"Error: tool '{fn_name}' is not available to sub-agents."

            _tool_dur_ms = int((time.perf_counter() - _tool_t0) * 1000)
            # Sanitize for LiteLLM
            result_str = result_str.encode("utf-8", "replace").decode("utf-8")
            if not result_str.isascii():
                result_str = result_str.encode("ascii", "backslashreplace").decode("ascii")

            _dur_str = f"{_tool_dur_ms}ms" if _tool_dur_ms < 1000 else f"{_tool_dur_ms / 1000:.1f}s"
            print(f"[sub:{label or 'sub'}] ← {fn_name} ({_dur_str}): {result_str[:200].replace(chr(10), ' ')}", flush=True)

            _tool_result: dict = {"role": "tool", "tool_call_id": tc.id, "content": result_str}
            messages.append(_tool_result)
            if sub_cp is not None:
                sub_cp.record("tool", duration_ms=_tool_dur_ms)

        if sub_cp is not None:
            sub_cp.step(messages, "in_progress")

    # Exhausted turns
    if sub_cp is not None:
        sub_cp.step(messages, "completed")
    return last_response or f"[sub_agent] Reached max turns ({max_turns})"
{% endif %}
