# yaml-language-server: $schema=https://schema.ninetrix.io/agentfile.json
# docs: https://docs.ninetrix.io
schema_version: "1.1"

governance:
  max_budget_per_run: 1.00
  human_approval:
    enabled: true
    actions:
      - file_write
      - shell_exec
  rate_limit: 10_requests_per_minute

triggers:
  - type: webhook
    endpoint: /run

# persistence:
#   provider: "postgres"
#   url: "${DATABASE_URL}"

agents:
  {{ key }}:
    metadata:
      name: {{ name }}
      description: {{ description }}
      role: "AI Assistant"
      goal: "Help users accomplish their tasks accurately and efficiently"
      instructions: |
        Be concise, accurate, and helpful.
        Always verify information before presenting it as fact.
        Use available tools when they can provide better or more current information.
      constraints:
        - "Do not make up information or present speculation as fact"
        - "Stay within the scope of your defined role and goal"
    runtime:
      provider: {{ provider }}
      model: {{ model }}
      temperature: {{ temperature }}
      # max_tokens: 8192             # max output tokens per LLM call
      # max_turns: 20                # safety cap on agentic loop iterations
      # tool_timeout: 30             # seconds before a tool call is aborted
      # history_window_tokens: 90000 # sliding-window token budget
    tools:
      - name: web_search
        source: mcp://duckduckgo
    # Composio tools — connect 250+ apps (GitHub, Slack, Gmail, Linear, Jira, etc.)
    # Requires COMPOSIO_API_KEY in your .env — get one at https://app.composio.dev
    # - name: github
    #   source: composio://GITHUB
    # - name: gmail
    #   source: composio://GMAIL
    #   actions:             # optional: limit to specific actions
    #     - GMAIL_SEND_EMAIL
    # Skills — reusable prompt-layer playbooks (SKILL.md with frontmatter)
    # skills:
    #   - hub://code-review@1.0.0        # from Skills Hub (version pinned)
    #   - ./skills/my-playbook            # local directory with SKILL.md
    collaborators: []
    # transfer_timeout: 300          # seconds before a collaborator transfer times out
    # routing:                       # how to route to collaborators
    #   mode: agent                  # "agent" (LLM decides) | "auto" (cheap router picks)
    #   model: claude-haiku-4-5-20251001
    # output_type:                   # structured JSON output (optional)
    #   type: object
    #   required: [answer]
    #   properties:
    #     answer: {type: string}
    # execution:
    #   mode: planned              # "direct" (default) | "planned" (plan-then-execute)
    #   verify_steps: true         # call a verifier LLM after each tool call
    #   max_steps: 10              # cap on plan size
    #   on_step_failure: continue  # "abort" | "continue" | "retry_once"
    #   verifier:
    #     provider: anthropic      # defaults to agent's provider
    #     model: claude-haiku-4-5-20251001   # small/fast model recommended
    #     max_tokens: 128

# Environment overrides — only specify what changes per environment.
# Usage: agentfile build --environment dev
#        agentfile run   --environment prod
